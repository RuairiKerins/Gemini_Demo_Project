<%= form_with url: home_analyze_path,
              html: { multipart: true, class: "flex flex-col gap-4" },
              local: true do |f| %>

  <label class="text-sm font-medium">Upload video</label>
  <%= f.file_field :video,
        direct_upload: true,
        accept: "video/*",
        class: "block w-full" %>

  <p class="text-xs text-gray-500">
    Short clips work best. MP4 recommended.
  </p>

  <%= f.submit "Analyze",
        class: "inline-flex rounded-md bg-gray-900 px-4 py-2 
        text-white hover:bg-gray-600" %>
<% end %>