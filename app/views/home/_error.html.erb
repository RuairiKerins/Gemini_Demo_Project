<%= turbo_frame_tag(
    "response",
    data: { visibility_target: "hideable" } 
    ) do %>
    <div class="p-4 border rounded bg-red-50 text-red-900">
        <strong>Something went wrong:</strong> <%= message %>
    </div>
    <%= button_tag "Retry",
        class: "inline-flex rounded-md bg-gray-900 px-4 py-2 
        text-white hover:bg-gray-600", 
        data: { action: "click->visibility#toggleVisibility" } 
    %>
<% end %>