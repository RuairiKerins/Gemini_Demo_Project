<body class="min-h-screen bg-white flex flex-col">
   <!-- Header -->
  <header class="border-b border-slate-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
      <a href="#" class="font-semibold">Create Academy Gemini Project</a>
      <nav class="hidden sm:flex items-center gap-6 text-sm text-gray-600">
        <a href="#" class="hover:text-gray-900">Home</a>
        <a href="#" class="hover:text-gray-900">About</a>
        <a href="#" class="hover:text-gray-900">Contact</a>
      </nav>
    </div>
  </header>

  <!-- Main Content -->
  <main class="py-24 flex-grow">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight">Upload A video below</h1>
      <p class="mt-4 text-base sm:text-lg text-gray-600">We will analyse it for you and recommend some of our courses for you</p>
      <div class="mt-8 mx-auto max-w-md border-2 border-slate-200 rounded-lg p-6 text-left">
        placeholder for upload form
        <%# render "form" %>
      </div>
    </div>
  </main>

  <!-- Footer -->
  <footer class="border-t">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between text-sm text-gray-600">
      <p>© <span id="year"></span> Acme. All rights reserved.</p>
      <div class="flex items-center gap-4">
        <a href="#" class="hover:text-gray-900">Privacy</a>
        <a href="#" class="hover:text-gray-900">Terms</a>
      </div>
    </div>
  </footer>
</body>